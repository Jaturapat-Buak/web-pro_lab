<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Phone Store</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">
</head>
<body class="bg-light">

<!-- 🔥 Navbar -->
<nav class="navbar navbar-expand-lg navbar-dark bg-dark shadow-sm">
  <div class="container">
    <a class="navbar-brand fw-bold" href="/">📱 PhoneStore</a>

    <div class="collapse navbar-collapse">
      <ul class="navbar-nav ms-auto">
        <li class="nav-item">
          <a class="nav-link" href="/">Home</a>
        </li>
        <li class="nav-item">
          <a class="nav-link active" href="/menu">Products</a>
        </li>
        <li class="nav-item">
          <a class="nav-link" href="/cart">Cart 🛒</a>
        </li>
      </ul>
    </div>
  </div>
</nav>

<div class="container py-5">
    <h1 class="text-center mb-5 fw-bold">Our Products</h1>

    <div class="row g-4">
        <% data.forEach((item)=>{ %>
            <div class="col-md-4">
                <div class="card shadow-sm h-100 border-0 product-card">
                    
                    <img src="http://webdev.it.kmitl.ac.th/phone-images/<%= item.pimage %>" 
                         class="card-img-top" 
                         style="height:250px; object-fit:cover;">

                    <div class="card-body text-center">
                        <h5 class="card-title fw-semibold"><%= item.name %></h5>

                        <p class="text-muted mb-1">
                            Storage: <%= item.storage %>
                        </p>

                        <p class="text-muted mb-3">
                            Camera: <%= item.camera %>
                        </p>

                        <h4 class="text-primary mb-3">
                            $<%= item.price %>
                        </h4>

                        <a href="/add-to-cart/<%= item.id %>" 
                           class="btn btn-dark w-100">
                           Add to Cart
                        </a>
                    </div>
                </div>
            </div>
        <% }); %>
    </div>
</div>

<!-- ✨ Hover Effect -->
<style>
.product-card {
    transition: transform 0.2s ease, box-shadow 0.2s ease;
}
.product-card:hover {
    transform: translateY(-5px);
    box-shadow: 0 10px 25px rgba(0,0,0,0.15);
}
</style>

</body>
</html>