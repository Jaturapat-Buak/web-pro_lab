<!DOCTYPE html>
<html>
<head>
    <meta charset="UTF-8">
    <title>Detail</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">
</head>
<body class="bg-light">

<div class="container mt-4">
    <div class="card shadow p-4">

        <h1 class="mb-4">
            Product <%= data.product_id %> Detail
        </h1>
        <img src="<%= data.image_url %>" 
            alt="<%= data.name %>" 
            class="img-fluid rounded mb-3 d-block mx-auto w-50">
        <h3><%= data.name %></h3>
        <p class="text-muted">
            Description : <%= data.description %>
        </p>
        <p>Price : <%= data.price %></p>
        <p>Amount : <%= data.quantity %></p>
        <a href="/" class="btn btn-primary mt-2">
            Go Back
        </a>
    </div>
</div>

</body>
</html>