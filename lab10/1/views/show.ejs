<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">
    <title>Show</title>
</head>
<body>
    <h1 style="text-align: center;">My Product</h1>
    <div id = "container">
        <% data.forEach((item)=>{ %>
        <div class = card>
            <img src="<%=item.image_url%>" alt="<%= item.name %>"width="500" ><br>
            <h4><%=item.name%></h4><br><p><%=item.description%></p>
            <a href="/detail/<%= item.product_id %>" class="btn btn-info btn-sm" >Detail</a>
        </div>
        <% }); %> 
    </div>  
</body>
</html>

<style>
    body {
        padding-left : 200px;
        padding-right : 200px;
        padding-bottom: 100px;
    }

    #container {
        display: grid;
        grid-template-columns: repeat(4, 1fr);
        gap: 20px;
    }

    .card {
        border: 2px solid rgb(199, 199, 199);
        background-color: white;
        display: flex;
        flex-direction: column;
        overflow: hidden;
        height: 450px;

    }

    .card img {
        width: 100%;
        height: 250px;
        object-fit: cover;
    }

    .card h4,
    .card p {
        padding: 0 15px;
    }

    .card p {
        flex-grow: 1;
    }
</style>